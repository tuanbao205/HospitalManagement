<Page x:Class="HospitalManagement.Pages.ChangePasswordPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:HospitalManagement.ViewModels"
      Title="Đổi mật khẩu">

    <Page.DataContext>
        <vm:ChangePasswordViewModel/>
    </Page.DataContext>

    <Grid>
        <Border Padding="40" HorizontalAlignment="Center"
                VerticalAlignment="Center" Width="420">
            <Border Background="White" CornerRadius="12"
                    BorderBrush="#E0E0E0" BorderThickness="1"
                    Padding="32">
                <StackPanel>
                    <TextBlock Text="Đổi mật khẩu" FontSize="22"
                               FontWeight="Bold" Foreground="#1976D2"
                               Margin="0,0,0,24"/>

                    <TextBlock Text="Mật khẩu cũ *" FontSize="12" Margin="0,0,0,4"/>
                    <PasswordBox x:Name="PwdOld" Height="36" Padding="10,6"
                                 FontSize="13" BorderBrush="#BDBDBD"
                                 Margin="0,0,0,14"
                                 PasswordChanged="PwdOld_PasswordChanged"/>

                    <TextBlock Text="Mật khẩu mới *" FontSize="12" Margin="0,0,0,4"/>
                    <PasswordBox x:Name="PwdNew" Height="36" Padding="10,6"
                                 FontSize="13" BorderBrush="#BDBDBD"
                                 Margin="0,0,0,14"
                                 PasswordChanged="PwdNew_PasswordChanged"/>

                    <TextBlock Text="Xác nhận mật khẩu *" FontSize="12" Margin="0,0,0,4"/>
                    <PasswordBox x:Name="PwdConfirm" Height="36" Padding="10,6"
                                 FontSize="13" BorderBrush="#BDBDBD"
                                 Margin="0,0,0,14"
                                 PasswordChanged="PwdConfirm_PasswordChanged"/>

                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="Red" FontSize="12"
                               Margin="0,0,0,16"
                               Visibility="{Binding HasError,
                                   Converter={StaticResource BoolToVisConverter}}"/>

                    <Button Content="🔑 Đổi mật khẩu" Height="42"
                            FontSize="14" Background="#1976D2"
                            Foreground="White" BorderThickness="0"
                            Margin="0,0,0,8"
                            Command="{Binding ChangePasswordCommand}"/>

                    <Button Content="🔄 Làm mới" Height="38"
                            FontSize="13" Background="#757575"
                            Foreground="White" BorderThickness="0"
                            Command="{Binding ClearCommand}"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Page>