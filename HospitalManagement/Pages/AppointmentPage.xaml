<Page x:Class="HospitalManagement.Pages.AppointmentPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:HospitalManagement.ViewModels"
      Title="Lịch khám">

    <Page.DataContext>
        <vm:AppointmentViewModel/>
    </Page.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="340"/>
        </Grid.ColumnDefinitions>

        <!-- Tiêu đề -->
        <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                   Text="Quản lý lịch khám" FontSize="22" FontWeight="Bold"
                   Foreground="#1976D2" Margin="0,0,0,16"/>

        <!-- Danh sách lịch khám -->
        <DataGrid Grid.Row="1" Grid.Column="0" Margin="0,0,16,0"
                  ItemsSource="{Binding Appointments}"
                  SelectedItem="{Binding SelectedAppointment}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  Background="White"
                  BorderBrush="#E0E0E0"
                  RowBackground="White"
                  AlternatingRowBackground="#FAFAFA"
                  FontSize="13">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"
                                    Binding="{Binding AppointmentId}" Width="45"/>
                <DataGridTextColumn Header="Bệnh nhân"
                                    Binding="{Binding Patient.FullName}" Width="*"/>
                <DataGridTextColumn Header="Bác sĩ"
                                    Binding="{Binding Doctor.FullName}" Width="*"/>
                <DataGridTextColumn Header="Ngày giờ"
                                    Binding="{Binding Date, StringFormat=dd/MM/yyyy HH:mm}"
                                    Width="130"/>
                <DataGridTextColumn Header="Trạng thái"
                                    Binding="{Binding Status}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Form bên phải -->
        <Border Grid.Row="1" Grid.Column="1"
                Background="White" CornerRadius="8"
                BorderBrush="#E0E0E0" BorderThickness="1"
                Padding="20">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Đặt lịch / Sửa lịch - chỉ Admin thấy -->
                    <StackPanel Visibility="{Binding IsAdmin,
                        Converter={StaticResource BoolToVisConverter}}">
                        <TextBlock Text="Đặt lịch mới" FontSize="15"
                                   FontWeight="Bold" Margin="0,0,0,16"/>

                        <TextBlock Text="Bệnh nhân *" FontSize="12" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding Patients}"
                                  SelectedItem="{Binding SelectedPatient}"
                                  DisplayMemberPath="FullName"
                                  Height="34" FontSize="13" Margin="0,0,0,10"/>

                        <TextBlock Text="Bác sĩ *" FontSize="12" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding Doctors}"
                                  SelectedItem="{Binding SelectedDoctor}"
                                  DisplayMemberPath="FullName"
                                  Height="34" FontSize="13" Margin="0,0,0,10"/>

                        <TextBlock Text="Ngày khám" FontSize="12" Margin="0,0,0,4"/>
                        <DatePicker SelectedDate="{Binding AppointmentDate}"
                                    Height="34" FontSize="13" Margin="0,0,0,10"/>

                        <TextBlock Text="Giờ khám" FontSize="12" Margin="0,0,0,4"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox Grid.Column="0"
                                      ItemsSource="{Binding Hours}"
                                      SelectedItem="{Binding AppointmentHour}"
                                      Height="34" FontSize="13"/>
                            <TextBlock Grid.Column="1" Text=":" FontSize="18"
                                       VerticalAlignment="Center" Margin="8,0"/>
                            <ComboBox Grid.Column="2"
                                      ItemsSource="{Binding Minutes}"
                                      SelectedItem="{Binding AppointmentMinute}"
                                      Height="34" FontSize="13"/>
                        </Grid>

                        <Button Content="{Binding BookButtonText}" Height="38" FontSize="13"
                                Background="#43A047" Foreground="White"
                                BorderThickness="0" Margin="0,0,0,8"
                                Command="{Binding BookCommand}"/>
                        <Button Content="🔄 Làm mới" Height="38" FontSize="13"
                                Background="#757575" Foreground="White"
                                BorderThickness="0" Margin="0,0,0,16"
                                Command="{Binding ClearCommand}"/>

                        <Separator Margin="0,0,0,16"/>
                    </StackPanel>

                    <!-- Cập nhật trạng thái -->
                    <TextBlock Text="Cập nhật trạng thái" FontSize="15"
                               FontWeight="Bold" Margin="0,0,0,16"/>

                    <TextBlock Text="Trạng thái" FontSize="12" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding StatusOptions}"
                              SelectedItem="{Binding SelectedStatus}"
                              Height="34" FontSize="13" Margin="0,0,0,10"/>

                    <Button Content="✏️ Cập nhật trạng thái" Height="38" FontSize="13"
                            Background="#1976D2" Foreground="White"
                            BorderThickness="0" Margin="0,0,0,8"
                            Command="{Binding UpdateStatusCommand}"/>
                    <Button Content="❌ Hủy lịch" Height="38" FontSize="13"
                            Background="#E53935" Foreground="White"
                            BorderThickness="0" Margin="0,0,0,8"
                            Command="{Binding CancelCommand}"/>
                    <Button Content="🗑️ Xóa lịch" Height="38" FontSize="13"
                            Background="#B71C1C" Foreground="White"
                            BorderThickness="0"
                            Command="{Binding DeleteCommand}"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>