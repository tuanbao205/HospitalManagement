<Page x:Class="HospitalManagement.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:HospitalManagement.ViewModels"
      Title="Dashboard">

    <Page.DataContext>
        <vm:DashboardViewModel/>
    </Page.DataContext>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30">

            <!-- Welcome -->
            <TextBlock Text="{Binding WelcomeText}"
                       FontSize="24" FontWeight="Bold"
                       Foreground="#1976D2" Margin="0,0,0,4"/>
            <TextBlock FontSize="13" Foreground="#757575" Margin="0,0,0,30">
                <Run Text="Hôm nay: "/>
                <Run Text="{Binding Source={x:Static system:DateTime.Now},
                    StringFormat='dd/MM/yyyy', Mode=OneTime}"
                     xmlns:system="clr-namespace:System;assembly=mscorlib"/>
            </TextBlock>

            <!-- Row 1: Số liệu chính -->
            <TextBlock Text="Tổng quan hệ thống" FontSize="16"
                       FontWeight="Bold" Margin="0,0,0,16"/>

            <UniformGrid Rows="1" Columns="4" Margin="0,0,0,24">

                <!-- Card bệnh nhân -->
                <Border Background="#E3F2FD" CornerRadius="12"
                        Margin="0,0,12,0" Padding="20">
                    <StackPanel>
                        <TextBlock Text="👥" FontSize="32" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding TotalPatients}"
                                   FontSize="36" FontWeight="Bold"
                                   Foreground="#1565C0"/>
                        <TextBlock Text="Bệnh nhân" FontSize="13"
                                   Foreground="#1976D2"/>
                    </StackPanel>
                </Border>

                <!-- Card bác sĩ -->
                <Border Background="#E8F5E9" CornerRadius="12"
                        Margin="0,0,12,0" Padding="20">
                    <StackPanel>
                        <TextBlock Text="👨‍⚕️" FontSize="32" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding TotalDoctors}"
                                   FontSize="36" FontWeight="Bold"
                                   Foreground="#2E7D32"/>
                        <TextBlock Text="Bác sĩ" FontSize="13"
                                   Foreground="#388E3C"/>
                    </StackPanel>
                </Border>

                <!-- Card lịch hôm nay -->
                <Border Background="#FFF3E0" CornerRadius="12"
                        Margin="0,0,12,0" Padding="20">
                    <StackPanel>
                        <TextBlock Text="📅" FontSize="32" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding TodayAppointments}"
                                   FontSize="36" FontWeight="Bold"
                                   Foreground="#E65100"/>
                        <TextBlock Text="Lịch hôm nay" FontSize="13"
                                   Foreground="#F57C00"/>
                    </StackPanel>
                </Border>

                <!-- Card hồ sơ -->
                <Border Background="#F3E5F5" CornerRadius="12"
                        Padding="20">
                    <StackPanel>
                        <TextBlock Text="📁" FontSize="32" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding TotalMedicalRecords}"
                                   FontSize="36" FontWeight="Bold"
                                   Foreground="#6A1B9A"/>
                        <TextBlock Text="Hồ sơ bệnh án" FontSize="13"
                                   Foreground="#7B1FA2"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Row 2: Trạng thái lịch khám -->
            <TextBlock Text="Trạng thái lịch khám" FontSize="16"
                       FontWeight="Bold" Margin="0,0,0,16"/>

            <UniformGrid Rows="1" Columns="2" Margin="0,0,0,24">

                <!-- Scheduled -->
                <Border Background="White" CornerRadius="12"
                        BorderBrush="#E0E0E0" BorderThickness="1"
                        Margin="0,0,12,0" Padding="24">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Chờ khám" FontSize="14"
                                       Foreground="#757575"/>
                            <TextBlock Text="{Binding ScheduledAppointments}"
                                       FontSize="40" FontWeight="Bold"
                                       Foreground="#1976D2"/>
                        </StackPanel>
                        <Border Grid.Column="1" Background="#E3F2FD"
                                CornerRadius="50" Width="60" Height="60">
                            <TextBlock Text="⏳" FontSize="28"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Done -->
                <Border Background="White" CornerRadius="12"
                        BorderBrush="#E0E0E0" BorderThickness="1"
                        Padding="24">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Đã khám" FontSize="14"
                                       Foreground="#757575"/>
                            <TextBlock Text="{Binding DoneAppointments}"
                                       FontSize="40" FontWeight="Bold"
                                       Foreground="#43A047"/>
                        </StackPanel>
                        <Border Grid.Column="1" Background="#E8F5E9"
                                CornerRadius="50" Width="60" Height="60">
                            <TextBlock Text="✅" FontSize="28"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>
            </UniformGrid>

        </StackPanel>
    </ScrollViewer>
</Page>