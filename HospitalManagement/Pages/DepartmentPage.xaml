<Page x:Class="HospitalManagement.Pages.DepartmentPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:HospitalManagement.ViewModels">

    <Page.DataContext>
        <vm:DepartmentViewModel/>
    </Page.DataContext>

    <Grid Margin="20">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0">

            <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                   Text="Quản lý phòng ban" FontSize="22" FontWeight="Bold"
                   Foreground="#1976D2" Margin="0,0,0,16"/>

            <StackPanel Orientation="Horizontal">

                <TextBox Width="300"
                         Height="30"
                         Text="{Binding SearchKeyword}" />

                <Button Content="Tìm kiếm"
                        Margin="10,0"
                        Command="{Binding SearchCommand}" />
            </StackPanel>

            <DataGrid Margin="0,10,0,0"
                      ItemsSource="{Binding Departments}"
                      SelectedItem="{Binding SelectedDepartment}"
                      AutoGenerateColumns="False">

                <DataGrid.Columns>

                    <DataGridTextColumn
                        Header="ID"
                        Binding="{Binding DepartmentId}" />

                    <DataGridTextColumn
                        Header="Tên phòng ban"
                        Binding="{Binding DepartmentName}" />

                    <DataGridTextColumn
                        Header="Mô tả"
                        Binding="{Binding Description}" />

                </DataGrid.Columns>

            </DataGrid>

        </StackPanel>

        <StackPanel Grid.Column="1" Margin="20,0,0,0">

            <TextBlock Text="Tên phòng ban"/>

            <TextBox Text="{Binding DepartmentName}" />

            <TextBlock Text="Mô tả"
                       Margin="0,10,0,0"/>

            <TextBox Text="{Binding Description}"
                     Height="100"
                     AcceptsReturn="True"/>

            <Button Content="Thêm"
                    Margin="0,15,0,0"
                    Command="{Binding AddCommand}" />

            <Button Content="Cập nhật"
                    Margin="0,5,0,0"
                    Command="{Binding UpdateCommand}" />

            <Button Content="Xóa"
                    Margin="0,5,0,0"
                    Command="{Binding DeleteCommand}" />

            <Button Content="Làm mới"
                    Margin="0,5,0,0"
                    Command="{Binding ClearCommand}" />

        </StackPanel>

    </Grid>
</Page>