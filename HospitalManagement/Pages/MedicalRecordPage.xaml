<Page x:Class="HospitalManagement.Pages.MedicalRecordPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:HospitalManagement.ViewModels"
      Title="Hồ sơ bệnh án">

    <Page.DataContext>
        <vm:MedicalRecordViewModel/>
    </Page.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="360"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                   Text="Hồ sơ bệnh án" FontSize="22" FontWeight="Bold"
                   Foreground="#1976D2" Margin="0,0,0,16"/>

        <DataGrid Grid.Row="1" Grid.Column="0" Margin="0,0,16,0"
                  ItemsSource="{Binding Records}"
                  SelectedItem="{Binding SelectedRecord}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  Background="White"
                  BorderBrush="#E0E0E0"
                  RowBackground="White"
                  AlternatingRowBackground="#FAFAFA"
                  FontSize="13">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"
                                    Binding="{Binding RecordId}" Width="45"/>
                <DataGridTextColumn Header="Bệnh nhân"
                                    Binding="{Binding Appointment.Patient.FullName}"
                                    Width="*"/>
                <DataGridTextColumn Header="Bác sĩ"
                                    Binding="{Binding Appointment.Doctor.FullName}"
                                    Width="*"/>
                <DataGridTextColumn Header="Ngày khám"
                                    Binding="{Binding Appointment.Date,
                                        StringFormat=dd/MM/yyyy HH:mm}"
                                    Width="130"/>
                <DataGridTextColumn Header="Chẩn đoán"
                                    Binding="{Binding Diagnosis}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="1" Grid.Column="1"
                Background="White" CornerRadius="8"
                BorderBrush="#E0E0E0" BorderThickness="1"
                Padding="20">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Chi tiết hồ sơ" FontSize="15"
                               FontWeight="Bold" Margin="0,0,0,16"/>

                    <StackPanel Visibility="{Binding IsDoctor,
                        Converter={StaticResource BoolToVisConverter}}">
                        <TextBlock Text="Chọn lịch khám *" FontSize="12" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding Appointments}"
                                  SelectedItem="{Binding SelectedAppointment}"
                                  Height="34" FontSize="13" Margin="0,0,0,10">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock>
                                        <Run Text="{Binding Patient.FullName}"/>
                                        <Run Text=" - "/>
                                        <Run Text="{Binding Date, StringFormat=dd/MM/yyyy HH:mm}"/>
                                    </TextBlock>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="Bệnh nhân:" FontSize="12"
                                   Foreground="#757575" Margin="0,0,0,6"/>
                        <TextBlock Grid.Row="0" Grid.Column="1"
                                   Text="{Binding PatientInfo}"
                                   FontSize="12" FontWeight="Bold" Margin="0,0,0,6"/>
                        <TextBlock Grid.Row="1" Grid.Column="0"
                                   Text="Bác sĩ:" FontSize="12"
                                   Foreground="#757575" Margin="0,0,0,6"/>
                        <TextBlock Grid.Row="1" Grid.Column="1"
                                   Text="{Binding DoctorInfo}"
                                   FontSize="12" FontWeight="Bold" Margin="0,0,0,6"/>
                        <TextBlock Grid.Row="2" Grid.Column="0"
                                   Text="Ngày khám:" FontSize="12"
                                   Foreground="#757575"/>
                        <TextBlock Grid.Row="2" Grid.Column="1"
                                   Text="{Binding AppointmentDate}"
                                   FontSize="12" FontWeight="Bold"/>
                    </Grid>

                    <Separator Margin="0,4,0,12"/>

                    <TextBlock Text="Chẩn đoán *" FontSize="12" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding Diagnosis, UpdateSourceTrigger=PropertyChanged}"
                             Height="70" Padding="10,6" FontSize="13"
                             BorderBrush="#BDBDBD" TextWrapping="Wrap"
                             AcceptsReturn="True" Margin="0,0,0,10"/>

                    <TextBlock Text="Đơn thuốc" FontSize="12" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding Prescription, UpdateSourceTrigger=PropertyChanged}"
                             Height="70" Padding="10,6" FontSize="13"
                             BorderBrush="#BDBDBD" TextWrapping="Wrap"
                             AcceptsReturn="True" Margin="0,0,0,10"/>

                    <TextBlock Text="Ghi chú" FontSize="12" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding Note, UpdateSourceTrigger=PropertyChanged}"
                             Height="60" Padding="10,6" FontSize="13"
                             BorderBrush="#BDBDBD" TextWrapping="Wrap"
                             AcceptsReturn="True" Margin="0,0,0,16"/>

                    <Button Content="{Binding SaveButtonText}" Height="38" FontSize="13"
                            Background="#43A047" Foreground="White"
                            BorderThickness="0" Margin="0,0,0,8"
                            Command="{Binding SaveCommand}"/>
                    <Button Content="🗑️ Xóa hồ sơ" Height="38" FontSize="13"
                            Background="#E53935" Foreground="White"
                            BorderThickness="0" Margin="0,0,0,8"
                            Command="{Binding DeleteCommand}"
                            Visibility="{Binding IsDoctor,
                                Converter={StaticResource BoolToVisConverter}}"/>
                    <Button Content="🔄 Làm mới" Height="38" FontSize="13"
                            Background="#757575" Foreground="White"
                            BorderThickness="0"
                            Command="{Binding ClearCommand}"/>
                    <Button Content="🖨️ In hồ sơ" Height="38" FontSize="13"
                            Background="#0277BD" Foreground="White"
                            BorderThickness="0" Margin="0,8,0,8"
                            Command="{Binding PrintCommand}"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>