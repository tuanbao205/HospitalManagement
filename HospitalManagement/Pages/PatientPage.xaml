<Page x:Class="HospitalManagement.Pages.PatientPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:HospitalManagement.ViewModels"
      Title="Quản lý bệnh nhân">

    <Page.DataContext>
        <vm:PatientViewModel/>
    </Page.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- Tiêu đề -->
        <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                   Text="Quản lý bệnh nhân" FontSize="22" FontWeight="Bold"
                   Foreground="#1976D2" Margin="0,0,0,16"/>

        <!-- Danh sách bên trái -->
        <Grid Grid.Row="1" Grid.Column="0" Margin="0,0,16,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Thanh tìm kiếm -->
            <Grid Grid.Row="0" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Height="34"
                         Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}"
                         Padding="10,6" FontSize="13"
                         BorderBrush="#BDBDBD"/>
                <Button Grid.Column="1" Content="Tìm" Width="70" Height="34"
                        Margin="8,0,0,0" Background="#1976D2" Foreground="White"
                        BorderThickness="0" Command="{Binding SearchCommand}"/>
                <Button Grid.Column="2" Content="Tất cả" Width="70" Height="34"
                        Margin="4,0,0,0" Background="#757575" Foreground="White"
                        BorderThickness="0" Command="{Binding ClearCommand}"/>
            </Grid>

            <!-- DataGrid -->
            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding Patients}"
                      SelectedItem="{Binding SelectedPatient}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      Background="White"
                      BorderBrush="#E0E0E0"
                      RowBackground="White"
                      AlternatingRowBackground="#FAFAFA"
                      FontSize="13">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding PatientId}" Width="50"/>
                    <DataGridTextColumn Header="Họ tên" Binding="{Binding FullName}" Width="*"/>
                    <DataGridTextColumn Header="Giới tính" Binding="{Binding Gender}" Width="80"/>
                    <DataGridTextColumn Header="Điện thoại" Binding="{Binding Phone}" Width="110"/>
                    <DataGridTextColumn Header="Địa chỉ" Binding="{Binding Address}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- Form bên phải -->
        <Border Grid.Row="1" Grid.Column="1"
                Background="White" CornerRadius="8"
                BorderBrush="#E0E0E0" BorderThickness="1"
                Padding="20">
            <StackPanel>
                <TextBlock Text="Thông tin bệnh nhân" FontSize="15"
                           FontWeight="Bold" Margin="0,0,0,16"/>

                <TextBlock Text="Họ và tên *" FontSize="12" Margin="0,0,0,4"/>
                <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"
                         Height="34" Padding="10,6" FontSize="13"
                         BorderBrush="#BDBDBD" Margin="0,0,0,10"/>

                <TextBlock Text="Ngày sinh" FontSize="12" Margin="0,0,0,4"/>
                <DatePicker SelectedDate="{Binding DOB}"
                            Height="34" FontSize="13" Margin="0,0,0,10"/>

                <TextBlock Text="Giới tính" FontSize="12" Margin="0,0,0,4"/>
                <ComboBox SelectedItem="{Binding Gender}"
                          Height="34" FontSize="13" Margin="0,0,0,10"
                          ItemsSource="{Binding GenderOptions}"/>

                <TextBlock Text="Số điện thoại *" FontSize="12" Margin="0,0,0,4"/>
                <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                         Height="34" Padding="10,6" FontSize="13"
                         BorderBrush="#BDBDBD" Margin="0,0,0,10"/>

                <TextBlock Text="Địa chỉ" FontSize="12" Margin="0,0,0,4"/>
                <TextBox Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"
                         Height="34" Padding="10,6" FontSize="13"
                         BorderBrush="#BDBDBD" Margin="0,0,0,20"/>

                <!-- Buttons -->
                <Button Content="➕ Thêm mới" Height="38" FontSize="13"
                        Background="#43A047" Foreground="White" BorderThickness="0"
                        Command="{Binding AddCommand}" Margin="0,0,0,8"/>
                <Button Content="✏️ Cập nhật" Height="38" FontSize="13"
                        Background="#1976D2" Foreground="White" BorderThickness="0"
                        Command="{Binding UpdateCommand}" Margin="0,0,0,8"/>
                <Button Content="🗑️ Xóa" Height="38" FontSize="13"
                        Background="#E53935" Foreground="White" BorderThickness="0"
                        Command="{Binding DeleteCommand}" Margin="0,0,0,8"/>
                <Button Content="🔄 Làm mới form" Height="38" FontSize="13"
                        Background="#757575" Foreground="White" BorderThickness="0"
                        Command="{Binding ClearCommand}"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>