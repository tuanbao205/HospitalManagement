<Window x:Class="HospitalManagement.Views.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:HospitalManagement.ViewModels"
        Title="Đổi mật khẩu" Height="390" Width="400"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">

    <Window.DataContext>
        <vm:ChangePasswordViewModel/>
    </Window.DataContext>

    <Border Padding="30">
        <StackPanel>
            <TextBlock Text="Đổi mật khẩu" FontSize="18"
                       FontWeight="Bold" Foreground="#1976D2"
                       Margin="0,0,0,24"/>

            <TextBlock Text="Mật khẩu cũ *" FontSize="12" Margin="0,0,0,4"/>
            <PasswordBox x:Name="PwdOld" Height="36" Padding="10,6"
                         FontSize="13" BorderBrush="#BDBDBD"
                         Margin="0,0,0,12"
                         PasswordChanged="PwdOld_PasswordChanged"/>

            <TextBlock Text="Mật khẩu mới *" FontSize="12" Margin="0,0,0,4"/>
            <PasswordBox x:Name="PwdNew" Height="36" Padding="10,6"
                         FontSize="13" BorderBrush="#BDBDBD"
                         Margin="0,0,0,12"
                         PasswordChanged="PwdNew_PasswordChanged"/>

            <TextBlock Text="Xác nhận mật khẩu *" FontSize="12" Margin="0,0,0,4"/>
            <PasswordBox x:Name="PwdConfirm" Height="36" Padding="10,6"
                         FontSize="13" BorderBrush="#BDBDBD"
                         Margin="0,0,0,12"
                         PasswordChanged="PwdConfirm_PasswordChanged"/>

            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="Red" FontSize="12" Margin="0,0,0,16"
                       Visibility="{Binding HasError,
                           Converter={StaticResource BoolToVisConverter}}"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="Hủy" Height="38"
                        FontSize="13" Background="#757575"
                        Foreground="White" BorderThickness="0"
                        Command="{Binding CancelCommand}"/>
                <Button Grid.Column="2" Content="Đổi mật khẩu" Height="38"
                        FontSize="13" Background="#1976D2"
                        Foreground="White" BorderThickness="0"
                        Command="{Binding ChangePasswordCommand}"/>
            </Grid>
        </StackPanel>
    </Border>
</Window>