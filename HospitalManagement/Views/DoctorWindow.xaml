<Window x:Class="HospitalManagement.Views.DoctorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quản lý bệnh viện - Bác sĩ" Height="650" Width="1100"
        WindowStartupLocation="CenterScreen" MinWidth="900" MinHeight="500">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#2E7D32">
            <StackPanel>
                <Border Background="#1B5E20" Padding="16,20">
                    <StackPanel>
                        <TextBlock Text="👨‍⚕️" FontSize="28" HorizontalAlignment="Center"/>
                        <TextBlock Text="BÁC SĨ" FontSize="13" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center"
                                   Margin="0,6,0,0"/>
                        <TextBlock x:Name="lblUsername" FontSize="11"
                                   Foreground="#C8E6C9" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Button Content="📅  Lịch khám của tôi" Style="{StaticResource MenuButton}"
                        Background="#2E7D32" Click="BtnMyAppointments_Click"
                        Margin="0,16,0,0"/>
                <Button Content="📁  Hồ sơ bệnh án" Style="{StaticResource MenuButton}"
                        Background="#2E7D32" Click="BtnMedicalRecords_Click"/>
                <Button Content="🔑  Đổi mật khẩu" Style="{StaticResource MenuButton}"
                        Background="#2E7D32" Click="BtnChangePassword_Click"/>

                <Button Content="🚪  Đăng xuất" Style="{StaticResource MenuButton}"
                        Background="#B71C1C" Click="BtnLogout_Click"
                        Margin="0,300,0,0"/>
            </StackPanel>
        </Border>

        <!-- Content area -->
        <Border Grid.Column="1" Background="#F5F5F5">
            <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden"/>
        </Border>
    </Grid>
</Window>