<Window x:Class="HospitalManagement.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:HospitalManagement.ViewModels"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Đăng nhập hệ thống" Height="420" Width="420"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignFont}">

    <Window.DataContext>
        <vm:LoginViewModel/>
    </Window.DataContext>

    <Border Padding="40">
        <StackPanel VerticalAlignment="Center">

            <TextBlock Text="🏥" FontSize="40"
                       HorizontalAlignment="Center" Margin="0,0,0,8"/>
            <TextBlock Text="HỆ THỐNG QUẢN LÝ BỆNH VIỆN"
                       FontSize="13" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="0,0,0,30"/>

            <TextBox materialDesign:HintAssist.Hint="Tên đăng nhập"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,16"/>

            <PasswordBox materialDesign:HintAssist.Hint="Mật khẩu"
                         Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                         x:Name="PwdBox"
                         PasswordChanged="PwdBox_PasswordChanged"
                         Margin="0,0,0,8"/>

            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="Red" FontSize="12" Margin="0,0,0,16"
                       Visibility="{Binding HasError,
                           Converter={StaticResource BoolToVisConverter}}"/>

            <Button Content="ĐĂNG NHẬP"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Height="44" FontSize="14" FontWeight="Bold"
                    Command="{Binding LoginCommand}"/>
        </StackPanel>
    </Border>
</Window>