<Window x:Class="HospitalManagement.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:HospitalManagement.ViewModels"
        Title="Đăng nhập hệ thống" Height="380" Width="420"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">

    <Window.DataContext>
        <vm:LoginViewModel/>
    </Window.DataContext>

    <Border Background="#F5F5F5">
        <StackPanel VerticalAlignment="Center" Margin="50,0">

            <TextBlock Text="🏥" FontSize="40" 
                       HorizontalAlignment="Center" Margin="0,0,0,8"/>
            <TextBlock Text="HỆ THỐNG QUẢN LÝ BỆNH VIỆN"
                       FontSize="13" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="0,0,0,30"/>

            <TextBlock Text="Tên đăng nhập" FontSize="12" Margin="0,0,0,4"/>
            <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                     Height="36" Padding="10,8" FontSize="13"
                     BorderBrush="#BDBDBD" BorderThickness="1"/>

            <TextBlock Text="Mật khẩu" FontSize="12" Margin="0,12,0,4"/>
            <PasswordBox x:Name="PwdBox" Height="36" Padding="10,8" FontSize="13"
                         BorderBrush="#BDBDBD" BorderThickness="1"
                         PasswordChanged="PwdBox_PasswordChanged"/>

            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="Red" FontSize="11" Margin="0,8,0,0"
                       Visibility="{Binding HasError, 
                           Converter={StaticResource BoolToVisConverter}}"/>

            <Button Content="ĐĂNG NHẬP" Height="40" Margin="0,20,0,0"
                    FontSize="13" FontWeight="Bold"
                    Background="#1976D2" Foreground="White"
                    BorderThickness="0" Cursor="Hand"
                    Command="{Binding LoginCommand}"/>
        </StackPanel>
    </Border>
</Window>