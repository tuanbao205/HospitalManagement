<Window x:Class="HospitalManagement.Views.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quản lý bệnh viện - Admin" Height="650" Width="1100"
        WindowStartupLocation="CenterScreen" MinWidth="900" MinHeight="500">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#1976D2">
            <StackPanel>
                <!-- Header -->
                <Border Background="#1565C0" Padding="16,20">
                    <StackPanel>
                        <TextBlock Text="🏥" FontSize="28" HorizontalAlignment="Center"/>
                        <TextBlock Text="ADMIN" FontSize="13" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center"
                                   Margin="0,6,0,0"/>
                        <TextBlock x:Name="lblUsername" FontSize="11"
                                   Foreground="#BBDEFB" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Menu buttons -->
                <Button Content="🏠  Dashboard" Style="{StaticResource MenuButton}"
                        Click="BtnDashboard_Click" />
                <Button Content="📋  Bệnh nhân" Style="{StaticResource MenuButton}"
                        Click="BtnPatients_Click" />
                <Button Content="👨‍⚕️  Bác sĩ" Style="{StaticResource MenuButton}"
                        Click="BtnDoctors_Click"/>
                <Button Content="📅  Đặt lịch khám" Style="{StaticResource MenuButton}"
                        Click="BtnAppointments_Click"/>
                <Button Content="📁  Hồ sơ bệnh án" Style="{StaticResource MenuButton}"
                        Click="BtnMedicalRecords_Click"/>
                <Button Content="👤  Tài khoản" Style="{StaticResource MenuButton}"
                        Click="BtnUsers_Click"/>

                <!-- Logout -->
                <Button Content="🚪  Đăng xuất" Style="{StaticResource MenuButton}"
                        Click="BtnLogout_Click" Margin="0,300,0,0"
                        Background="#C62828"/>
            </StackPanel>
        </Border>

        <!-- Content area -->
        <Border Grid.Column="1" Background="#F5F5F5">
            <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden"/>
        </Border>
    </Grid>
</Window>